<plist version="1.0">
<dict>
  <key>Label</key>
  <string>com.filelay.icloud-file-sync</string>

  <key>ProgramArguments</key>
  <array>
    <string>/Users/alex/Documents/VibeCoding/Filelay/icloud_file_sync.sh</string>
    <string>--source</string>
    <string>/Users/alex/Documents/your-local-file.txt</string>
